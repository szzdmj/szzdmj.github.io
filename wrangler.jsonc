{
  "name": "szzdmj-github-io",
  "main": "src/index.ts",
  "compatibility_date": "2025-08-01",
  "compatibility_flags": ["nodejs_compat"],
  "services": [
    { "binding": "CONTAINER", "service": "routenewcontainer" }
  ],
    "placement": {
    "mode": "smart"
  },
  "assets": {
    "directory": "./dist/"
  }
}
